# PostgreSQL connection strings (Supabase recommended)
DATABASE_URL="database_url_here"
DIRECT_URL="direct_url_here"

# Public web URL used in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_OTP_MINUTES=10

# Email OTP configuration (use a real SMTP account or leave blank for console fallback)
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="xyz@gmail.com" # Replace with your actual email address
EMAIL_SERVER_PASSWORD="your-app-password-here" # Use an app password for Gmail
EMAIL_FROM="abc@edu.in" # Replace with your desired sender email address

# OTP expiry (minutes)
OTP_EXP_MINUTES=10

# Session auth secret (generate a long random value)
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SESSION_SECONDS=43200